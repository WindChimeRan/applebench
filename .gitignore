# Framework source code
.frameworks/

# Python virtual environments
.venvs/

# Model files
.models/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# vllm-metal installer temp files
vllm-*/

# Metalstat sidecar artifacts — per-cell GPU/mem/power timelines written
# next to benchmark result JSONs. Kept on disk for local diagnosis, not
# committed (they grow ~1-2 MB/week and aren't needed by downstream consumers).
results/**/*_metalstat.jsonl
results/**/*_metalstat.meta.json

# Per-request model output sidecars (content + reasoning text, one JSON per
# line per successful request). Used for cross-framework output comparison
# during diagnosis; not committed (~3-5 MB/week, text-heavy, low reuse value).
results/**/*_outputs.jsonl
